pipeline{
  agent any
  

    stages {

      stage ('git pull') {
       steps { 
        git branch: 'devops' , url: 'https://github.com/jyotiparmar208/three-tier-infra.git
    }
}
     stage ("Docker-backend-build") {
         steps{
          sh ''' 
           cd backend
            docker build -t jyotiparmar208/jugnoo-backend .'''
    }
} 
   stage ("Docker-frontend-build") {
     steps { 
       sh ''' 
        cd frontend
        docker build -t jyotiparmar208/jugnoo-frontend .'''
    }
}
  stage ( "Docker-push") {
     steps {
      sh '''
      docker push jyotiparmar208/jugnoo-backend
      docker push jyotiparmar208/jugnoo-frontend '''
  }
}
   stage('Deploy to EKS') {
            steps {
                sh '''
                aws eks --region us-east-1 update-kubeconfig --name three-tier-eks
                kubectl apply -f main.yaml
                '''
            }    
    }
  }
}






